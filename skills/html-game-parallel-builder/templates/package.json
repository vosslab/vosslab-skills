{
	"name": "game-project",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"scripts": {
		"setup": "./devel/setup_typescript.sh",
		"setup:playwright": "./devel/setup_playwright.sh",
		"build": "./build_github_pages.sh",
		"serve": "./run_web_server.sh",
		"check": "./check_codebase.sh",
		"clean": "./dist_clean.sh",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"typecheck:lint": "tsc --noEmit -p tsconfig.lint.json",
		"lint": "eslint --max-warnings 0 'src/**/*.ts' 'tests/**/*.ts' '*.ts'",
		"format": "prettier --write 'src/**/*.{ts,css,html,json}' 'tests/**/*.ts'",
		"format:check": "prettier --check 'src/**/*.{ts,css,html,json}' 'tests/**/*.ts'",
		"test:node": "node --test 'tests/test_*.mjs'",
		"test:playwright": "playwright test",
		"export:single": "./export_single_file.sh"
	},
	"devDependencies": {
		"esbuild": ">=0.28.1",
		"typescript": ">=6.0.3",
		"eslint": ">=10.5.0",
		"@eslint/js": ">=10.0.1",
		"typescript-eslint": ">=8.61.1",
		"globals": ">=17.6.0",
		"playwright": ">=1.61.0",
		"prettier": ">=3.8.4",
		"@playwright/test": ">=1.61.0"
	}
}
